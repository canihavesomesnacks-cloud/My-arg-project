<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mysterious System</title>
<style>
    body {
        background-color: #000;
        color: #0f0;
        font-family: monospace;
        padding: 10px;
    }
    #terminal {
        border: 1px solid #0f0;
        padding: 10px;
        height: 70vh;
        overflow-y: auto;
        white-space: pre-wrap;
    }
    input {
        width: 100%;
        background-color: #000;
        color: #0f0;
        border: none;
        font-family: monospace;
        font-size: 1em;
    }
</style>
</head>
<body>
<h2>You stumbled upon a mysterious system</h2>
<div id="terminal"></div>
<input id="commandInput" placeholder="Type command and press Enter" autofocus>

<script>
const STORAGE_KEY = "mysteriousSystemState";
let state = JSON.parse(localStorage.getItem(STORAGE_KEY)) || {
    discovered_clues: [],
    system_version: 1,
    hidden_messages: [
        "The key is under the desk.",
        "Look for the red folder.",
        "Some secrets only appear at night..."
    ],
    secret_triggers: [
        {clues_needed: 2, message: "SYSTEM ALERT: Unusual activity detected..."},
        {clues_needed: 3, message: "ACCESS GRANTED TO HIDDEN MODULE"}
    ]
};

function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
}

const terminal = document.getElementById("terminal");

function typeLine(text, delay = 50) {
    return new Promise(resolve => {
        let i = 0;
        function typeChar() {
            if (i < text.length) {
                terminal.textContent += text[i];
                i++;
                terminal.scrollTop = terminal.scrollHeight;
                setTimeout(typeChar, delay);
            } else {
                terminal.textContent += "\n";
                terminal.scrollTop = terminal.scrollHeight;
                resolve();
            }
        }
        typeChar();
    });
}

async function discoverClue() {
    const unseen = state.hidden_messages.filter(m => !state.discovered_clues.includes(m));
    if (unseen.length > 0) {
        const clue = unseen[Math.floor(Math.random() * unseen.length)];
        state.discovered_clues.push(clue);
        state.system_version += 1;
        saveState();
        await typeLine(`New clue discovered! System version ${state.system_version}`);
        await typeLine(`Clue: ${clue}`);
        checkSecretTriggers();
    } else {
        await typeLine("All clues discovered. The system is silent... for now.");
    }
}

async function showStatus() {
    await typeLine(`System Version: ${state.system_version}`);
    await typeLine(`Clues found (${state.discovered_clues.length}/${state.hidden_messages.length}):`);
    state.discovered_clues.forEach(c => terminal.textContent += ` - ${c}\n`);
    terminal.scrollTop = terminal.scrollHeight;
}

async function checkSecretTriggers() {
    state.secret_triggers.forEach(trigger => {
        if (state.discovered_clues.length >= trigger.clues_needed && !trigger.triggered) {
            trigger.triggered = true;
            typeLine(trigger.message, 50);
        }
    });
    saveState();
}

// Handle commands
document.getElementById("commandInput").addEventListener("keydown", async (e) => {
    if (e.key === "Enter") {
        const cmd = e.target.value.trim().toLowerCase();
        terminal.textContent += `> ${cmd}\n`;
        e.target.value = "";
        if (cmd === "discover") await discoverClue();
        else if (cmd === "status") await showStatus();
        else await typeLine("Unknown command. Try 'discover' or 'status'.");
    }
});

// Auto-updating logs
setInterval(() => {
    const messages = ["SYSTEM CHECK: OK", "DATA SYNCHRONIZED", "NO ANOMALIES DETECTED"];
    if (Math.random() < 0.2) { // 20% chance every interval
        typeLine(messages[Math.floor(Math.random() * messages.length)], 40);
    }
}, 5000);

</script>
</body>
</html>